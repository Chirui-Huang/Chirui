---
layout: null
---
[
  {% assign searchable_pages = site.html_pages | where_exp: "item", "item.url != '/404.html'" %}
  {% assign searchable_posts = site.posts %}

  {% for page in searchable_pages %}
    {% assign page_url = site.baseurl | append: page.url %}
    {
      "title": {{ page.title | default: page.url | strip_html | normalize_whitespace | jsonify }},
      "category": {{ "Page" | jsonify }},
      "tags": {{ "" | jsonify }},
      "url": {{ page_url | jsonify }},
      "date": {{ "" | jsonify }},
      "content": {{ page.content | strip_html | normalize_whitespace | jsonify }}
    }{% unless forloop.last and searchable_posts.size == 0 %},{% endunless %}
  {% endfor %}

  {% for post in searchable_posts %}
    {% assign post_url = site.baseurl | append: post.url %}
    {
      "title": {{ post.title | strip_html | normalize_whitespace | jsonify }},
      "category": {{ post.category | default: "Post" | jsonify }},
      "tags": {{ post.tags | array_to_sentence_string | jsonify }},
      "url": {{ post_url | jsonify }},
      "date": {{ post.date | date_to_xmlschema | jsonify }},
      "content": {{ post.content | strip_html | normalize_whitespace | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
