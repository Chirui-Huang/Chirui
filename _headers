# GitHub Pages Security Headers Configuration
# Note: GitHub Pages doesn't support custom headers via _headers file
# These headers should be set via meta tags in HTML (already done in _includes/head.html)
# or via a CDN/proxy like Cloudflare if using custom domain

# If deploying to a platform that supports _headers (Netlify, Vercel, etc.):

/*
  # Security Headers
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' translate.google.com translate-a.googleapis.com cdn.jsdelivr.net googletagmanager.com analytics.google.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://chirui-huang.pockethost.io translate.googleapis.com; frame-src 'self' youtube.com www.youtube.com *.youtube.com; object-src 'none'; base-uri 'self'; form-action 'self' https://formspree.io; upgrade-insecure-requests

# Security.txt location
/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8

# Force HTTPS
http://*
  Location: https://:splat 301!
